{
  "name": "knockout-arena",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "dev": "pnpm --parallel --filter @knockout/server --filter @knockout/client dev",
    "build": "pnpm -r build",
    "start": "node apps/server/dist/index.js",
    "test": "pnpm -r test",
    "test:production": "node apps/server/scripts/production-smoke.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint apps packages --max-warnings=0",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0"
  }
}
